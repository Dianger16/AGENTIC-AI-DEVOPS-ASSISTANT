# .env.example — copy to .env

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct:nitro

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── Kubernetes ────────────────────────────────────────────────────────────────
EKS_CLUSTER_NAME=agentic-devops
KUBECONFIG=~/.kube/config          # auto-set by: aws eks update-kubeconfig

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090   # port-forwarded from EKS

# ── GitHub Actions (for pipeline triggering) ──────────────────────────────────
GITHUB_TOKEN=ghp_...               # from github.com/settings/tokens
GITHUB_REPO=YOUR_USERNAME/YOUR_REPO

# ── Agent config ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_ITERATIONS=10                  # max agent reasoning steps
